# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env
#
# For production, copy to .env.prod and set strong secrets:
#   cp .env.example .env.prod
#   python -c "import secrets; print(f'SECRET_KEY={secrets.token_hex(32)}')"
#   python -c "import secrets; print(f'POSTGRES_PASSWORD={secrets.token_urlsafe(32)}')"
#   python -c "import secrets; print(f'REDIS_PASSWORD={secrets.token_urlsafe(16)}')"

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_32_chars_min
POSTGRES_DB=fraud_db

# ─── Backend ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_at_least_64_hex_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_redis_password
CELERY_BROKER_URL=redis://:CHANGE_ME_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_redis_password@redis:6379/2

# ─── ML ──────────────────────────────────────────────────────────────────────
MODEL_ARTIFACTS_PATH=/app/app/ml/artifacts
DEFAULT_THRESHOLD=0.5
# CREDITCARD_CSV_PATH=/path/to/creditcard.csv

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ─── Flower (Celery Monitor) ─────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_flower_password
